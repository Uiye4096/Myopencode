{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-v4-pro",
  "instructions": [
    "./prompts/global-rules.md"
  ],
  "small_model": "deepseek/deepseek-v4-flash",
  "agent": {
    "build": {
      "prompt": "{file:./prompts/build.txt}"
    },
    "plan": {
      "prompt": "{file:./prompts/plan.txt}"
    },
    "eyjafjalla": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "variant": "medium",
      "temperature": 0.85,
      "top_p": 0.95,
      "description": "Roleplay as Eyjafjalla from Arknights",
      "prompt": "{file:./prompts/eyjafjalla.txt}"
    },
    "muelsyse": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "variant": "medium",
      "temperature": 0.9,
      "top_p": 0.95,
      "description": "Roleplay as Muelsyse from Arknights",
      "prompt": "{file:./prompts/muelsyse.txt}"
    },
    "aemeath": {
      "mode": "primary",
      "model": "deepseek/deepseek-v4-pro",
      "variant": "medium",
      "temperature": 0.95,
      "top_p": 0.97,
      "description": "Roleplay as Aemeath from Wuthering Waves",
      "prompt": "{file:./prompts/aemeath.txt}"
    }
  },
  "mcp": {
    "crawl4ai": {
      "type": "local",
      "command": [
        "python3",
        "/Users/uiye2048/.config/opencode/scripts/crawl4ai-server.py",
        "stdio"
      ]
    },
    "ticktick": {
      "type": "remote",
      "url": "http://1.14.94.240:8090/mcp"
    },
    "notion": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "NOTION_TOKEN": "{env:NOTION_TOKEN}"
      }
    },
    "playwright": {
      "type": "remote",
      "url": "http://localhost:8931/mcp"
    }
  }
}
